  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  termId         String      @db.ObjectId
  term           Term        @relation(fields: [termId], references: [id])
 
  // Fee types
  uniformType      String?
  uniformFee       Float       @default(0)
  medicalFeeType   String?
  tuitionFeeType   String?
  tuitionFee       Float       @default(0)
  transportFee     Float       @default(0)
  medicalFee       Float       @default(0)
  computerFee      Float       @default(0)
  libraryFee       Float       @default(0)
  developmentFee   Float       @default(0)
  otherFees        Float       @default(0)
 
  // NEW fields
  hairFee          Float       @default(0)
  debtFee          Float       @default(0)
  coversFee        Float       @default(0)
  packagesFee      Float       @default(0)
  regFee           Float       @default(0)
  snacksFee        Float       @default(0)
 
  // NEW multi-price entry arrays (JSON)
  tuitionEntries   Json?
  medicalEntries   Json?
  uniformEntries   Json?
  transportEntries Json?
 
  totalFee         Float       @default(0)
  isActive         Boolean     @default(true)
 
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  createdById      String?     @db.ObjectId
  createdBy        User?       @relation("FeeStructureCreatedBy", fields: [createdById], references: [id])
 
  studentFees      StudentFee[]
  invoices         Invoice[]
 
  @@unique([classId, academicYearId, termId])
  @@map("fee_structures")
}

model StudentFee {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  studentId        String      @db.ObjectId
  student          Student     @relation(fields: [studentId], references: [id])
  feeStructureId   String      @db.ObjectId
  feeStructure     FeeStructure @relation(fields: [feeStructureId], references: [id])
  classId          String      @db.ObjectId
  class            Class       @relation(fields: [classId], references: [id])
  academicYearId   String      @db.ObjectId
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id])
  termId           String      @db.ObjectId
  term             Term        @relation(fields: [termId], references: [id])

  // ── Type flags ──────────────────────────────────────────────────────────────
  uniformType      String?
  medicalFeeType   String?
  tuitionFeeType   String?

  // ── Core fee columns ────────────────────────────────────────────────────────
  tuitionFee       Float       @default(0)
  transportFee     Float       @default(0)
  medicalFee       Float       @default(0)
  computerFee      Float       @default(0)
  libraryFee       Float       @default(0)
  developmentFee   Float       @default(0)
  otherFees        Float       @default(0)
  uniformFee       Float       @default(0)

  // ── Extended fee columns (NEW — must match FeeStructure fields) ─────────────
  hairFee          Float       @default(0)   // hair-related charges
  debtFee          Float       @default(0)   // carried-over debt
  coversFee        Float       @default(0)   // book covers / stationery
  packagesFee      Float       @default(0)   // school supply packages
  regFee           Float       @default(0)   // registration / admission fee
  snacksFee        Float       @default(0)   // tuck-shop / snack programme

  // ── Multi-price JSON snapshots (mirrors FeeStructure) ──────────────────────
  tuitionEntries   Json?       // [{label, amount}] — copied at assignment time
  medicalEntries   Json?
  uniformEntries   Json?
  transportEntries Json?

  // ── Running totals (maintained by the API) ──────────────────────────────────
  totalFee         Float       @default(0)
  totalPaid        Float       @default(0)
  balance          Float       @default(0)

  status           FeeStatus   @default(PENDING)
  dueDate          DateTime?

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  createdById      String?     @db.ObjectId
  createdBy        User?       @relation("StudentFeeCreatedBy", fields: [createdById], references: [id])

  payments         FeePayment[]

  @@unique([studentId, feeStructureId])
  @@map("student_fees")
}


